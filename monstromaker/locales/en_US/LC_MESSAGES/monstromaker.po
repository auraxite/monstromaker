#, python-format
msgid "%(name)s сбросил %(card)s"
msgstr "%(name)s discarded %(card)s"

#: monstromaker/game.py:355 monstromaker/game.py:460
#, python-format
msgid "%(name)s - карт нет"
msgstr "%(name)s - no cards"

#: monstromaker/game.py:356 monstromaker/game.py:436
msgid "никто не пострадал"
msgstr "no one was hurt"

#: monstromaker/game.py:357
#, python-format
msgid "%(player)s взревел! %(summary)s."
msgstr "%(player)s roared! %(summary)s."

#: monstromaker/game.py:375
#, python-format
msgid "%(player)s использовал Шпиона - цель не выбрана."
msgstr "%(player)s used Spy - no target was chosen."

#: monstromaker/game.py:380
#, python-format
msgid "%(player)s тайно изучает чью-то руку..."
msgstr "%(player)s secretly studies someone's hand..."

#: monstromaker/game.py:392
#, python-format
msgid "%(player)s роется в сбросе - ничего не выбрано."
msgstr "%(player)s rummaged in the discard pile - nothing chosen."

#: monstromaker/game.py:397
#, python-format
msgid "%(player)s хотел взять из сброса - сброс пуст."
msgstr "%(player)s wanted to take from discard - pile is empty."

#: monstromaker/game.py:401
#, python-format
msgid "%(player)s достал из сброса: %(card)s."
msgstr "%(player)s took from discard: %(card)s."

#: monstromaker/game.py:421
#, python-format
msgid "%(name)s - БРОНЕЧЕШУЯ! Щит сработал, карта цела."
msgstr "%(name)s - ARMORSCALE! Shield worked, card saved."

#: monstromaker/game.py:428
#, python-format
msgid "%(name)s - нет щита! Теряет: %(card)s"
msgstr "%(name)s - no shield! Loses: %(card)s"

#: monstromaker/game.py:433
#, python-format
msgid "%(name)s - нет облик-карт, не пострадал."
msgstr "%(name)s - no appearance cards, unharmed."

#: monstromaker/game.py:437
#, python-format
msgid "%(player)s сыграл Пекло! %(summary)s."
msgstr "%(player)s played Inferno! %(summary)s."

#: monstromaker/game.py:462
#, python-format
msgid "%(event)s от %(player)s! %(summary)s."
msgstr "%(event)s by %(player)s! %(summary)s."

#: monstromaker/game.py:463
msgid "Экзамен по ОКам"
msgstr "Cybernetics Fundamentals exam"

#: monstromaker/game.py:494
#, python-format
msgid "%(player)s пасует."
msgstr "%(player)s passes."

